[
  {
    "toolId": "tool.read_file",
    "name": "read_file",
    "description": "Read a file from the sandbox filesystem.",
    "schema": {
      "type": "object",
      "properties": {
        "path": { "type": "string" }
      },
      "required": ["path"]
    },
    "parameters": [
      {
        "name": "path",
        "type": "string",
        "required": true,
        "description": "Sandbox file path to read."
      }
