  },
  {
    "toolId": "tool.write_file",
    "name": "write_file",
    "description": "Write content to a sandbox file path. This is simulated and never writes to the host filesystem.",
    "schema": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "content": { "type": "string" },
        "mode": { "type": "string", "enum": ["overwrite", "append"] }
      },
      "required": ["path", "content"]
    },
    "parameters": [
      {
        "name": "path",
        "type": "string",
        "required": true,
        "description": "Sandbox file path to write."
      },
      {
        "name": "content",
        "type": "string",
        "required": true,
        "description": "Content to write."
      },
      {
        "name": "mode",
        "type": "string",
        "required": false,
        "description": "Write mode, overwrite or append."
      }
    ],
    "riskTags": [
      {
        "tagId": "tag.file_write",
        "category": "dangerous_action",
        "level": "high",
        "description": "May modify files or persist malicious content."
      }
    ],
    "riskLevel": "high",
    "sideEffect": "write"
  },
  {
    "toolId": "tool.send_email",
