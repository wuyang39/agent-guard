{
  "name": "agent-guard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "demo": "node scripts/start-demo.mjs",
    "demo:p2": "node scripts/demo-p2.mjs",
    "demo:web": "node scripts/demo-web-server.mjs",
    "demo:sample-agent": "node scripts/sample-agent-server.mjs",
    "api:c": "node --import tsx backend/src/server.ts",
    "frontend": "vite --config frontend/vite.config.ts",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "test:frontend": "node --import tsx --test frontend/src/lib/api/realtime.test.ts frontend/src/lib/models/realtime.test.ts frontend/src/lib/models/defense.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:frontend": "tsc -p frontend/tsconfig.json --noEmit",
    "verify:c-api": "node --import tsx scripts/verify-c-api.ts",
    "verify:a-config-sandbox": "node --import tsx scripts/verify-a-config-sandbox.ts",
    "verify:a-pyrit-library": "node --import tsx scripts/verify-a-pyrit-library.ts",
    "a:index-pyrit": "node --import tsx scripts/index-pyrit-seed-datasets.ts",
    "a:index-aig": "node --import tsx scripts/index-aig-strategies.ts",
    "a:generate-corpus": "node --import tsx scripts/generate-a-corpus.ts",
    "a:pyrit-runtime": "node --import tsx scripts/generate-a-pyrit-runtime-batch.ts",
    "verify:a-corpus": "node --import tsx scripts/verify-a-corpus.ts",
    "verify:a-attack-cards": "node --import tsx scripts/verify-a-attack-cards.ts",
    "verify:a-pyrit-runtime": "node --import tsx scripts/verify-a-pyrit-runtime.ts",
    "pyrit:index-templates": "node --import tsx scripts/generate-pyrit-template-index.ts",
    "pyrit:setup-runtime": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-pyrit-runtime.ps1",
    "pyrit:bridge-smoke": "node --import tsx scripts/verify-pyrit-bridge-smoke.ts",
    "verify:all": "npm run typecheck && npm run verify:a-config-sandbox && npm run verify:a-pyrit-library && npm run verify:a-corpus && npm run verify:a-attack-cards && npm run verify:full-pipeline && npm run verify:p1:detection-policy && npm run verify:p1:supervision-defense && npm run verify:c:weekly",
    "verify:e2e": "node --import tsx scripts/verify-e2e-three-stage.ts",
    "verify:full-pipeline": "node --import tsx scripts/verify-full-pipeline.ts",
    "verify:c:weekly": "node --import tsx scripts/verify-c-weekly-deliverables.ts",
    "verify:p1:detection-policy": "node --import tsx scripts/verify-p1-detection-policy.ts",
    "verify:p1:supervision-defense": "node --import tsx scripts/verify-p1-supervision-defense.ts",
    "verify:p2:api-e2e": "node --import tsx scripts/verify-p2-api-e2e.ts",
    "verify:openclaw:realtime": "node --import tsx scripts/verify-openclaw-realtime-mcp.ts",
    "verify:p3:b-gateway": "node --import tsx scripts/verify-p3-b-gateway.ts",
    "verify:p3:b-llm-profiler": "node --import tsx scripts/verify-p3-b-llm-profiler.ts",
    "verify:p3:b-semantic-scorer": "node --import tsx scripts/verify-p3-b-semantic-scorer.ts",
    "verify:p3:b-tool-profile-policy": "node --import tsx scripts/verify-p3-b-tool-profile-policy.ts",
    "verify:p3:b-test-selection": "node --import tsx scripts/verify-p3-b-test-selection.ts",
    "verify:shared-llm-config": "node --import tsx scripts/verify-shared-llm-config.ts",
    "verify:p3:c-report": "node --import tsx scripts/verify-p3-c-report.ts",
    "api:start": "node --import tsx backend/src/server.ts",
    "api:dev": "node --watch --import tsx backend/src/server.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "fastify": "^5.8.5",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.20.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  }
}
