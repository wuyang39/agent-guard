{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@agent-guard/contracts": ["packages/contracts/src/index.ts"],
      "@agent-guard/contracts/*": ["packages/contracts/src/*"]
    }
  },
  "include": ["backend/src/**/*.ts", "packages/contracts/src/**/*.ts"]
}
